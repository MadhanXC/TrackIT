
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow authenticated users to read and write only their own work items
    match /workItems/{itemId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /inviteCodes/{codeId} {
      allow read: if true; // Needed for signup validation
      allow update: if true; // Needed to decrement usage
    }
  }
}
