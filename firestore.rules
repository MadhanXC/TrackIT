
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow authenticated users to read and write to the main collections
    match /workItems/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /addresses/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /inviteCodes/{codeId} {
      allow read: if true; // Needed for signup validation
      allow update: if true; // Needed to decrement usage
    }
  }
}
